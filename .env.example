# Copy this file to .env and customize before running docker-compose.
# This file is intentionally not loaded by git if you keep .env in .gitignore.

# MySQL settings
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_DATABASE=school_db
MYSQL_USER=school_user
MYSQL_PASSWORD=school_pass
DB_PORT=3306

# Backend settings
APP_ENV=local
JWT_SECRET=replace_with_a_long_random_secret
JWT_TTL=86400
CORS_ORIGIN=http://localhost:3000
BACKEND_HTTP_PORT=8000

# Frontend settings
FRONTEND_HTTP_PORT=3000
VITE_API_URL=http://localhost:8000/api

# phpMyAdmin
PHPMYADMIN_HTTP_PORT=8080
